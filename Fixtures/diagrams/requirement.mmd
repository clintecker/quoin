requirementDiagram

requirement flight_control_system {
    id: SYS-1
    text: The flight control system shall stabilise the airframe across the full operating envelope without pilot input
    risk: high
    verifymethod: analysis
}

functionalRequirement attitude_hold {
    id: FUN-1.1
    text: The autopilot shall maintain the commanded pitch and roll attitude within two degrees
    risk: medium
    verifymethod: test
}

functionalRequirement waypoint_navigation {
    id: FUN-1.2
    text: The system shall follow a loaded flight plan and sequence waypoints automatically
    risk: medium
    verifymethod: demonstration
}

performanceRequirement control_loop_rate {
    id: PRF-2.1
    text: The inner control loop shall execute at no less than two hundred hertz under worst case load
    risk: high
    verifymethod: analysis
}

performanceRequirement sensor_latency {
    id: PRF-2.2
    text: End to end sensor to actuator latency shall not exceed twelve milliseconds
    risk: high
    verifymethod: test
}

interfaceRequirement pilot_input_bus {
    id: IFC-3.1
    text: The sidestick interface shall publish normalised commands over the redundant avionics bus
    risk: low
    verifymethod: inspection
}

physicalRequirement actuator_redundancy {
    id: PHY-4.1
    text: Each primary control surface shall be driven by two independent actuators
    risk: high
    verifymethod: inspection
}

designConstraint mil_std_compliance {
    id: CON-5.1
    text: All flight critical software shall conform to the applicable airworthiness standard
    risk: medium
    verifymethod: inspection
}

element flight_computer {
    type: hardware
    docref: HW-Spec-FC-2200
}

element control_law_module {
    type: software
    docref: SW-CLM-rev-C
}

element imu_sensor_array {
